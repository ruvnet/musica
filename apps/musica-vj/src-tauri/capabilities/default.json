{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Least-privilege capability set for the main performance window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-save",
    "fs:allow-write-file",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister-all"
  ]
}
