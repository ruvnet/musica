{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Musica VJ",
  "version": "0.6.0",
  "identifier": "one.cognitum.musica.vj",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Musica VJ",
        "width": 1440,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost blob: data:; media-src 'self' asset: http://asset.localhost blob:; script-src 'self'; style-src 'self' 'unsafe-inline'; worker-src 'self' blob:; object-src 'none'; frame-src 'none'; base-uri 'none'; form-action 'none'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM0M0Y0OEIwRDk2NTM2MDMKUldRRE5tWFpzRWcvTkRZVGNoQnRDWVRBOXZ4anB5VGFXMVNDbHVMM0MyTUtQRGJWNnVBUklvRnMK",
      "endpoints": [
        "https://github.com/ruvnet/musica/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "category": "Music",
    "shortDescription": "Perform music and reactive visuals live",
    "longDescription": "A multi-track music synthesizer and real-time visual performance studio powered by Musica.",
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
