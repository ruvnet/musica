    "render:onboarding-previews": "node scripts/render-onboarding-previews.mjs",
    "render:samples": "node scripts/render-samples.mjs",
    "verify:samples": "node scripts/verify-samples.mjs",
    "verify:samples:reproducible": "node scripts/verify-reproducibility.mjs",
    "verify:assets": "node scripts/verify-assets.mjs",
    "verify:no-secrets": "node scripts/verify-no-secrets.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
