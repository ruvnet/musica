    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "6.0.3",
    "ffmpeg-static": "^5.3.0",
    "jsdom": "29.1.1",
