/target
Cargo.lock
!/Cargo.lock
.env
.env.*
*.wav
*.mp3
*.flac
!apps/musica-vj/samples/lyria/*.mp3
!apps/musica-vj/exports/*.mp3
test_audio/*.wav
apps/musica-vj/node_modules/
apps/musica-vj/dist/
apps/musica-vj/.vite/
apps/musica-vj/coverage/
apps/musica-vj/src-tauri/icons/*
!apps/musica-vj/src-tauri/icons/32x32.png
!apps/musica-vj/src-tauri/icons/128x128.png
!apps/musica-vj/src-tauri/icons/128x128@2x.png
!apps/musica-vj/src-tauri/icons/icon.icns
!apps/musica-vj/src-tauri/icons/icon.ico

# Codex local configuration
.codex/

# Claude Flow runtime data
.claude-flow/data/
.claude-flow/logs/

# Environment variables
.env
.env.local
.env.*.local

# Onboarding preview bank is runtime-required
!apps/musica-vj/public/previews/lyria/*.mp3

# Agent tooling runtime state must never ship
**/.claude-flow/
